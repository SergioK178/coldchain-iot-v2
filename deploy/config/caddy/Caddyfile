# Редирект www → основной домен (если DOMAIN не localhost)
www.{$DOMAIN:localhost} {
    redir https://{$DOMAIN:localhost}{uri} permanent
}

{$DOMAIN:localhost} {
    # /api/v1/* — напрямую в backend (health, ready и др.)
    handle /api/v1/* {
        reverse_proxy server:8080
    }
    # /api/auth/* — напрямую в backend (cookie от браузера к server без прокси)
    handle_path /api/auth/* {
        rewrite * /api/v1/auth{path}
        reverse_proxy server:8080
    }
    # Остальное — Next.js (страницы, /api/proxy)
    handle {
        reverse_proxy web:3000
    }
}
