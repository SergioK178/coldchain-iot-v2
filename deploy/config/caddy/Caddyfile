# Редирект www → основной домен (если DOMAIN не localhost)
www.{$DOMAIN:localhost} {
    redir https://{$DOMAIN:localhost}{uri} permanent
}

{$DOMAIN:localhost} {
    # /api/v1/* — напрямую в backend (health, ready и др.)
    handle /api/v1/* {
        reverse_proxy server:8080
    }
    # /api/auth/*, /api/proxy, страницы — Next.js
    # Caddy по умолчанию добавляет X-Forwarded-Proto (для Secure cookie)
    handle {
        reverse_proxy web:3000
    }
}
