# DO NOT COMMIT REAL SECRETS.
# Rotate immediately if secrets were ever committed.

# Required
DB_PASSWORD=
MQTT_ADMIN_PASSWORD=
JWT_SECRET=

# Optional (P1/P2 compatibility)
API_TOKEN=
ADMIN_EMAIL=
# Minimum recommended ADMIN_PASSWORD complexity:
# at least 16 chars, include lower/upper/digit/special.
ADMIN_PASSWORD=
ALERT_CALLBACK_URL=
TELEGRAM_BOT_TOKEN=

# Optional defaults
# DB_NAME=sensors
# DB_USER=sensors
# MQTT_PORT=1883
# MQTT_ADMIN_USER=server
# HTTP_PORT=8080
# WEB_PORT=3000
# DEVICE_OFFLINE_TIMEOUT_SEC=300
# AUTH_RATE_LIMIT_LOGIN_MAX=8
# AUTH_RATE_LIMIT_LOGIN_WINDOW_SEC=300
# AUTH_RATE_LIMIT_REFRESH_MAX=20
# AUTH_RATE_LIMIT_REFRESH_WINDOW_SEC=300
# AUTH_RATE_LIMIT_BLOCK_SEC=300
# AUTH_COOKIE_SECURE=auto   # true|false|auto
# WEBHOOK_ALLOWLIST_HOSTS=  # optional comma-separated hostnames
