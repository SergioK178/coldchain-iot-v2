# === ОБЯЗАТЕЛЬНЫЕ ===
# Все три значения нужно придумать самостоятельно перед первым запуском.
# Используйте надёжные случайные строки (минимум 16 символов, для API_TOKEN — 32+).
# Быстро сгенерировать: openssl rand -hex 16

# Пароль root-пользователя PostgreSQL.
# Пример: openssl rand -hex 16 → e.g. 4a8f1c3e7b2d9f0a5c6e8d1b3f7a2e4c
DB_PASSWORD=

# Пароль admin-пользователя MQTT (используется сервером для подключения к брокеру).
# Пример: openssl rand -hex 16
MQTT_ADMIN_PASSWORD=

# Bearer token для API-аутентификации (все запросы к API, кроме /health).
# Минимум 32 символа. Пример: openssl rand -hex 24
API_TOKEN=

# === ОПЦИОНАЛЬНЫЕ (значения по умолчанию указаны справа) ===

# DB_NAME=sensors
# DB_USER=sensors
# MQTT_PORT=1883
# MQTT_ADMIN_USER=server
# HTTP_PORT=8080
# DEVICE_OFFLINE_TIMEOUT_SEC=300

# URL для HTTP-уведомлений при тревоге. Если не задан — callback не отправляется.
# ALERT_CALLBACK_URL=http://192.168.1.100:9000/hooks/sensor


 #cd deploy                                                                                                               cp .env.example .env
                                                                                                                          Заполнить три обязательных поля:

  #┌─────────────────────┬─────────────────────────────────────────────────┬─────────────────────────────────────────┐
  #│     Переменная      │                     Что это                     │            Как сгенерировать            │
  #├─────────────────────┼─────────────────────────────────────────────────┼─────────────────────────────────────────┤
  #│ DB_PASSWORD         │ Пароль PostgreSQL                               │ openssl rand -hex 16                    │
  #├─────────────────────┼─────────────────────────────────────────────────┼─────────────────────────────────────────┤
  #│ MQTT_ADMIN_PASSWORD │ Пароль MQTT-админа (сервер подключается к       │ openssl rand -hex 16                    │
  #│                     │ брокеру)                                        │                                         │
  #├─────────────────────┼─────────────────────────────────────────────────┼─────────────────────────────────────────┤
  #│ API_TOKEN           │ Bearer token для всех API-запросов              │ openssl rand -hex 24 (минимум 32        │
  #│                     │                                                 │ символа)                                │
  #└─────────────────────┴─────────────────────────────────────────────────┴─────────────────────────────────────────┘

  #Остальное опционально — дефолты уже рабочие. После заполнения:

  #docker compose up -d