# DO NOT COMMIT REAL SECRETS.
# Rotate immediately if secrets were ever committed.

# ── Required ──────────────────────────────────────────────────────────────────
DB_PASSWORD=
MQTT_ADMIN_PASSWORD=
# Minimum 64 chars, cryptographically random (e.g. openssl rand -hex 64)
JWT_SECRET=

# ── Admin account (created on first start if ADMIN_EMAIL is set) ──────────────
ADMIN_EMAIL=
# Minimum 16 chars, include lower/upper/digit/special
ADMIN_PASSWORD=

# ── Optional: network ─────────────────────────────────────────────────────────
# Public URL of the API as seen by the browser (used by Next.js frontend).
# Set when the API is behind a reverse proxy or on a custom port/domain.
# PUBLIC_API_URL=http://localhost:8080

# ── Optional: ports ───────────────────────────────────────────────────────────
# HTTP_PORT=8080
# WEB_PORT=3000
# MQTT_PORT=1883

# ── Optional: internal service accounts ──────────────────────────────────────
# DB_NAME=sensors
# DB_USER=sensors
# MQTT_ADMIN_USER=server

# ── Preferred P2 Mosquitto reload path (F6) ─────────────────────────────────
# Internal auth-sync endpoint used by server for reconcile/reload.
# For compose default: http://mqtt:9080/reload
# MOSQUITTO_RELOAD_URL=http://mqtt:9080/reload

# ── Optional: device behaviour ───────────────────────────────────────────────
# DEVICE_OFFLINE_TIMEOUT_SEC=300

# ── Optional: auth rate-limiting ─────────────────────────────────────────────
# AUTH_RATE_LIMIT_LOGIN_MAX=8
# AUTH_RATE_LIMIT_LOGIN_WINDOW_SEC=300
# AUTH_RATE_LIMIT_REFRESH_MAX=20
# AUTH_RATE_LIMIT_REFRESH_WINDOW_SEC=300
# AUTH_RATE_LIMIT_BLOCK_SEC=300
# AUTH_COOKIE_SECURE=auto   # true | false | auto

# ── Optional: webhooks ────────────────────────────────────────────────────────
# Comma-separated list of allowed webhook destination hostnames.
# Leave empty to allow any reachable host (private/loopback targets are always rejected).
# WEBHOOK_ALLOWLIST_HOSTS=

# ── Optional: Telegram notifications ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Optional: Swagger UI (production) ─────────────────────────────────────────
# Set to false to disable /api/docs in production.
# SWAGGER_UI_ENABLED=false
