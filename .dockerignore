.env
.env.*
!.env.example
deploy/data
deploy/.env
deploy/config

# Tests and coverage (not needed for prod image)
**/__tests__
**/*.test.ts
**/*.spec.ts
coverage
.nyc_output

# Misc
*.log
*.tsbuildinfo
.DS_Store
